generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  AGENT
  USER
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum StageKind {
  TODO
  IN_PROGRESS
  VALIDATION
  DONE
}

enum ActivityType {
  COMMENT
  STAGE_CHANGE
  ASSIGN
  ATTACHMENT
  NOTE
}

enum SlaResult {
  IN_SLA
  BREACHED
}

model Solicitacao {
  id              String   @id @default(uuid())
  departamento    String
  email           String?
  protocolo       String?
  tipoSolicitacao String
  descricao       String   @db.LongText
  veiculacao      Json
  observacoes     String?  @db.LongText
  arquivoUrl      String?
  createdAt       DateTime @default(now())
  startedAt       DateTime?
  firstRespondedAt DateTime?
  completedAt     DateTime?
  archivedAt      DateTime?

  deliveryAt       DateTime

  stageId          String
  stage            Stage    @relation(fields: [stageId], references: [id])

  requesterId      String?
  requester        User?    @relation("Requester", fields: [requesterId], references: [id], onDelete: SetNull)

  assigneeId       String?
  assignee         User?    @relation("Assignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  priority         Priority @default(MEDIUM)
  slaMinutes       Int?
  slaTargetAt      DateTime?
  slaBreachedAt    DateTime?
  slaResult        SlaResult?

  stageHistory     SolicitacaoStageHistory[]
  activities       SolicitacaoActivity[]

  @@index([stageId, createdAt])
  @@index([assigneeId, createdAt])
  @@index([requesterId, createdAt])
  @@index([completedAt])
  @@index([priority])
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("user")
  roleEnum  Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  requestedSolicitacoes Solicitacao[]             @relation("Requester")
  assignedSolicitacoes  Solicitacao[]             @relation("Assignee")
  stageChanges          SolicitacaoStageHistory[] @relation("ChangedBy")
  activities            SolicitacaoActivity[]
}

model Stage {
  id        String    @id @default(uuid())
  name      String
  order     Int
  kind      StageKind @default(TODO)
  active    Boolean   @default(true)
  boardKey  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  solicitacoes Solicitacao[]

  fromHistory SolicitacaoStageHistory[] @relation("FromStage")
  toHistory   SolicitacaoStageHistory[] @relation("ToStage")

  @@index([boardKey, order])
  @@index([kind, active])
}

model SolicitacaoStageHistory {
  id            String   @id @default(uuid())
  solicitacaoId String

  fromStageId   String?
  toStageId     String

  changedAt     DateTime @default(now())
  changedById   String?

  solicitacao Solicitacao @relation(fields: [solicitacaoId], references: [id], onDelete: Cascade)

  fromStage   Stage? @relation("FromStage", fields: [fromStageId], references: [id], onDelete: SetNull)
  toStage     Stage  @relation("ToStage", fields: [toStageId], references: [id], onDelete: Cascade)

  changedBy   User?  @relation("ChangedBy", fields: [changedById], references: [id], onDelete: SetNull)

  @@index([solicitacaoId, changedAt])
  @@index([toStageId, changedAt])
  @@index([changedById, changedAt])
}

model SolicitacaoActivity {
  id            String       @id @default(uuid())
  solicitacaoId String
  type          ActivityType
  message       String?
  data          Json?
  createdAt     DateTime     @default(now())

  actorId       String?
  actor         User?        @relation(fields: [actorId], references: [id], onDelete: SetNull)

  solicitacao   Solicitacao  @relation(fields: [solicitacaoId], references: [id], onDelete: Cascade)

  @@index([solicitacaoId, createdAt])
  @@index([actorId, createdAt])
  @@index([type, createdAt])
}

model SlaPolicy {
  id              String    @id @default(uuid())
  active          Boolean   @default(true)
  tipoSolicitacao String?
  departamento    String?
  priority        Priority?
  minutesTarget   Int
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([active])
  @@index([priority])
  @@index([tipoSolicitacao])
  @@index([departamento])
}
